APP_ENV=integration
LOCAL_API_AUTH_REQUIRED=true
LOCAL_API_TOKEN=integration-only-token
CREDENTIAL_MASTER_KEY=integration-only-master-key-32-chars
DATABASE_URL=postgresql+asyncpg://assistant:assistant@postgres:5432/assistant_integration
POSTGRES_DB=assistant_integration
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant
REDIS_URL=redis://redis:6379/0
BROWSER_ENABLED=false
LANGBOT_API_KEY=placeholder-langbot-api-key
DEEPSEEK_API_KEY=placeholder-deepseek-api-key
TAVILY_API_KEY=placeholder-tavily-api-key
