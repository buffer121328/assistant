APP_ENV=local
LOG_LEVEL=INFO
SERVICE_NAME=assistant-api
LOCAL_API_AUTH_REQUIRED=true
LOCAL_API_TOKEN=
CREDENTIAL_MASTER_KEY=
MANAGED_SKILLS_ROOT=var/skills
MANAGED_PROMPTS_ROOT=var/prompts
SKILL_PACKAGES_ROOT=var/skill-packages
ARTIFACTS_ROOT=var/artifacts
SESSION_WORKSPACE_ROOT=var/workspace/sessions
KNOWLEDGE_ROOT=var/knowledge
BROWSER_STATE_ROOT=var/browser

BROWSER_ENABLED=false
BROWSER_TIMEOUT_SECONDS=20
BROWSER_MAX_TEXT_CHARS=50000

SANDBOX_PROVIDER=none
SHELL_EXEC_ENABLED=false
SANDBOX_WORKSPACE_ROOT=var/sandbox
SANDBOX_DOCKER_IMAGE=
SANDBOX_DOCKER_ALLOWED_IMAGES=
SANDBOX_TIMEOUT_SECONDS=30

SUBAGENT_ENABLED=true
SUBAGENT_MAX_COUNT=3
SUBAGENT_CONCURRENCY=2
SUBAGENT_TIMEOUT_SECONDS=30

MEM0_CONFIG_PATH=
MEM0_SEARCH_LIMIT=5

QUALITY_JUDGE_SAMPLE_RATE=0
QUALITY_JUDGE_POLICY_VERSION=judge-v1
QUALITY_JUDGE_THRESHOLD=0.6

DATABASE_URL=postgresql+asyncpg://assistant:assistant@postgres:5432/assistant
REDIS_URL=redis://redis:6379/0
SENTRY_DSN=

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

LANGBOT_WEBHOOK_SECRET=placeholder-langbot-webhook-secret
LANGBOT_API_BASE_URL=https://langbot.invalid
LANGBOT_API_KEY=placeholder-langbot-api-key
LANGBOT_SEND_TIMEOUT_SECONDS=10

DEEPSEEK_API_KEY=placeholder-deepseek-api-key
DEEPSEEK_BASE_URL=https://deepseek.invalid/v1
DEEPSEEK_LIGHT_MODEL=deepseek-light-placeholder
DEEPSEEK_STANDARD_MODEL=deepseek-standard-placeholder
MODEL_GATEWAY_TIMEOUT_SECONDS=10
MODEL_GATEWAY_RETRY_ATTEMPTS=2
# Additional OpenAI-compatible GLM/enterprise/private nodes; keep [] until configured.
MODEL_GATEWAY_NODES_JSON=[]

TAVILY_BASE_URL=https://tavily.invalid
TAVILY_API_KEY=placeholder-tavily-api-key
TAVILY_TIMEOUT_SECONDS=10
TAVILY_MAX_RESULTS=5
SEARCH_PROVIDER_ORDER=tavily,brave,duckduckgo
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1/web/search
DUCKDUCKGO_SEARCH_ENABLED=false
DUCKDUCKGO_SEARCH_BASE_URL=https://api.duckduckgo.com/
SEARCH_FALLBACK_ON_EMPTY=true
# Blank means reuse TAVILY_TIMEOUT_SECONDS for every provider.
SEARCH_PROVIDER_TIMEOUT_SECONDS=

RUNNING_TASK_TIMEOUT_SECONDS=300
PENDING_TASK_COMPENSATION_DELAY_SECONDS=120
SCHEDULER_MAINTENANCE_INTERVAL_SECONDS=300

# Explicit provider smoke only. Keep blank unless intentionally running
# `uv run python -m scripts.ops.provider_smoke` against test accounts.
SMOKE_LANGBOT_HEALTH_URL=
SMOKE_LANGBOT_API_KEY=
SMOKE_MODEL_GATEWAY_HEALTH_URL=
SMOKE_MODEL_GATEWAY_API_KEY=
SMOKE_TAVILY_BASE_URL=
SMOKE_TAVILY_API_KEY=
SMOKE_TAVILY_QUERY=OpenAI
SMOKE_SMTP_HOST=
SMOKE_SMTP_PORT=
SMOKE_SMTP_USERNAME=
SMOKE_SMTP_PASSWORD=
SMOKE_SMTP_FROM=
SMOKE_SMTP_RECIPIENT=
SMOKE_SMTP_SECURITY=
SMOKE_CALDAV_URL=
SMOKE_CALDAV_USERNAME=
SMOKE_CALDAV_PASSWORD=
SMOKE_CALDAV_CALENDAR_URL=
SMOKE_CALDAV_IDEMPOTENCY_KEY=provider-smoke-v1
SMOKE_BROWSER_URL=

# Workspace context tools read local project context through structured, bounded,
# readonly APIs. Keep deny globs conservative; do not include real secrets here.
WORKSPACE_CONTEXT_ROOT=.
WORKSPACE_CONTEXT_ENABLED=true
WORKSPACE_CONTEXT_DENY_GLOBS=.env,.env.*,**/.env,**/.env.*,.git/**,**/.git/**,node_modules/**,**/node_modules/**,__pycache__/**,**/__pycache__/**,*.pem,**/*.pem,*.key,**/*.key,*.p12,**/*.p12,*.sqlite,**/*.sqlite,*.db,**/*.db
WORKSPACE_CONTEXT_MAX_FILE_BYTES=200000
WORKSPACE_CONTEXT_MAX_RESULTS=50
READONLY_SHELL_ENABLED=false
READONLY_SHELL_TIMEOUT_SECONDS=10
READONLY_SHELL_MAX_OUTPUT_CHARS=50000
